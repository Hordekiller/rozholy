{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "1200px",
      "wideSize": "1400px"
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "Playfair Display, serif",
          "slug": "display",
          "name": "Display"
        },
        {
          "fontFamily": "Vazirmatn, IRANSans, Tahoma, sans-serif",
          "slug": "primary",
          "name": "Primary"
        },
        {
          "fontFamily": "Dancing Script, cursive",
          "slug": "accent",
          "name": "Accent"
        },
        {
          "fontFamily": "-apple-system, BlinkMacSystemFont, Segoe UI, Roboto, sans-serif",
          "slug": "system",
          "name": "System"
        }
      ],
      "fontSizes": [
        { "slug": "small", "name": "Small", "size": "0.875rem" },
        { "slug": "medium", "name": "Medium", "size": "1rem" },
        { "slug": "large", "name": "Large", "size": "1.25rem" },
        { "slug": "xl", "name": "XL", "size": "1.5rem" },
        { "slug": "2xl", "name": "2XL", "size": "2rem" },
        { "slug": "3xl", "name": "3XL", "size": "2.5rem" },
        { "slug": "4xl", "name": "4XL", "size": "3rem" },
        { "slug": "5xl", "name": "5XL", "size": "4rem" }
      ],
      "dropCap": false,
      "fluid": true
    },
    "color": {
      "palette": [
        { "slug": "primary", "name": "Primary Pink", "color": "#d4a0a0" },
        { "slug": "primary-dark", "name": "Primary Dark", "color": "#c08080" },
        { "slug": "primary-light", "name": "Primary Light", "color": "#f0d0d0" },
        { "slug": "secondary", "name": "Secondary Purple", "color": "#b8a0c0" },
        { "slug": "secondary-dark", "name": "Secondary Dark", "color": "#9870a8" },
        { "slug": "accent", "name": "Accent Gold", "color": "#c8a87c" },
        { "slug": "accent-light", "name": "Accent Light", "color": "#e8d0b8" },
        { "slug": "base", "name": "Base BG", "color": "#faf5f0" },
        { "slug": "base-alt", "name": "Base Alt BG", "color": "#f5ece4" },
        { "slug": "dark", "name": "Dark", "color": "#2d2d2d" },
        { "slug": "text", "name": "Text", "color": "#4a4a4a" },
        { "slug": "text-light", "name": "Text Light", "color": "#7a7a7a" },
        { "slug": "border", "name": "Border", "color": "#e8ddd5" },
        { "slug": "white", "name": "White", "color": "#ffffff" },
        { "slug": "black", "name": "Black", "color": "#000000" }
      ],
      "gradients": [
        {
          "slug": "primary-gradient",
          "name": "Primary Gradient",
          "gradient": "linear-gradient(135deg, #d4a0a0, #c08080)"
        },
        {
          "slug": "accent-gradient",
          "name": "Accent Gradient",
          "gradient": "linear-gradient(135deg, #c8a87c, #b8986c)"
        },
        {
          "slug": "dark-gradient",
          "name": "Dark Gradient",
          "gradient": "linear-gradient(135deg, #2d2d2d, #1e1e2a)"
        },
        {
          "slug": "service-gradient",
          "name": "Service Gradient",
          "gradient": "linear-gradient(135deg, #f0d0d0, #f5ece4)"
        }
      ],
      "link": false
    },
    "spacing": {
      "padding": true,
      "margin": true,
      "blockGap": true,
      "units": ["px", "em", "rem", "vh", "vw", "%"]
    },
    "border": {
      "radiusSizes": [
        { "slug": "small", "name": "Small", "size": "8px" },
        { "slug": "medium", "name": "Medium", "size": "16px" },
        { "slug": "large", "name": "Large", "size": "24px" },
        { "slug": "full", "name": "Full", "size": "999px" }
      ]
    },
    "shadow": {
      "presets": [
        { "slug": "soft", "name": "Soft", "shadow": "0 4px 20px rgba(0,0,0,0.06)" },
        { "slug": "strong", "name": "Strong", "shadow": "0 8px 30px rgba(0,0,0,0.12)" },
        { "slug": "glow", "name": "Glow", "shadow": "0 4px 15px rgba(212, 160, 160, 0.4)" }
      ]
    },
    "blocks": {
      "core/button": {
        "border": {
          "radius": "999px"
        },
        "typography": {
          "fontWeight": "600"
        }
      },
      "core/heading": {
        "typography": {
          "fontFamily": "var:preset|font-family|display",
          "fontWeight": "700",
          "lineHeight": "1.3"
        }
      },
      "core/post-title": {
        "typography": {
          "fontFamily": "var:preset|font-family|display"
        }
      },
      "core/site-title": {
        "typography": {
          "fontFamily": "var:preset|font-family|display",
          "fontSize": "var:preset|font-size|2xl"
        }
      },
      "core/navigation": {
        "typography": {
          "fontSize": "var:preset|font-size|medium"
        }
      },
      "core/quote": {
        "typography": {
          "fontStyle": "italic"
        },
        "border": {
          "radius": "8px"
        }
      },
      "core/pullquote": {
        "typography": {
          "fontFamily": "var:preset|font-family|display"
        }
      },
      "core/cover": {
        "color": {
          "palette": [
            {
              "slug": "overlay-dark",
              "name": "Overlay Dark",
              "color": "rgba(30, 30, 42, 0.6)"
            }
          ]
        }
      }
    }
  },
  "styles": {
    "color": {
      "background": "var:preset|color|base",
      "text": "var:preset|color|text"
    },
    "typography": {
      "fontFamily": "var:preset|font-family|primary",
      "lineHeight": "1.8",
      "fontSize": "var:preset|font-size|medium"
    },
    "spacing": {
      "padding": {
        "left": "var:preset|spacing|20",
        "right": "var:preset|spacing|20"
      }
    },
    "elements": {
      "link": {
        "color": {
          "text": "var:preset|color|primary-dark"
        },
        ":hover": {
          "color": {
            "text": "var:preset|color|primary"
          }
        },
        "typography": {
          "textDecoration": "none"
        }
      },
      "heading": {
        "color": {
          "text": "var:preset|color|dark"
        },
        "typography": {
          "fontFamily": "var:preset|font-family|display",
          "fontWeight": "700",
          "lineHeight": "1.3"
        },
        "spacing": {
          "margin": {
            "bottom": "0.5em"
          }
        }
      },
      "h1": {
        "typography": {
          "fontSize": "var:preset|font-size|4xl"
        }
      },
      "h2": {
        "typography": {
          "fontSize": "var:preset|font-size|3xl"
        }
      },
      "h3": {
        "typography": {
          "fontSize": "var:preset|font-size|xl"
        }
      },
      "h4": {
        "typography": {
          "fontSize": "var:preset|font-size|large"
        }
      },
      "button": {
        "color": {
          "background": "var:preset|color|primary",
          "text": "var:preset|color|white"
        },
        "typography": {
          "fontFamily": "var:preset|font-family|primary",
          "fontWeight": "600"
        },
        "border": {
          "radius": "999px"
        },
        "spacing": {
          "padding": {
            "top": "14px",
            "right": "32px",
            "bottom": "14px",
            "left": "32px"
          }
        },
        ":hover": {
          "color": {
            "background": "var:preset|color|primary-dark"
          }
        }
      },
      "caption": {
        "color": {
          "text": "var:preset|color|text-light"
        },
        "typography": {
          "fontSize": "var:preset|font-size|small"
        }
      },
      "input": {
        "color": {
          "text": "var:preset|color|text",
          "background": "var:preset|color|white"
        },
        "border": {
          "radius": "8px",
          "width": "2px",
          "color": "var:preset|color|border"
        },
        "typography": {
          "fontFamily": "var:preset|font-family|primary"
        },
        "spacing": {
          "padding": {
            "top": "12px",
            "right": "16px",
            "bottom": "12px",
            "left": "16px"
          }
        }
      }
    },
    "blocks": {
      "core/post-title": {
        "typography": {
          "fontSize": "var:preset|font-size|3xl"
        }
      },
      "core/site-title": {
        "typography": {
          "fontWeight": "700"
        }
      },
      "core/navigation": {
        "typography": {
          "fontWeight": "500"
        }
      },
      "core/social-links": {
        "spacing": {
          "blockGap": "8px"
        }
      },
      "core/query-pagination": {
        "spacing": {
          "padding": {
            "top": "30px",
            "bottom": "30px"
          }
        }
      },
      "core/separator": {
        "color": {
          "background": "var:preset|color|border"
        }
      }
    }
  },
  "customTemplates": [
    {
      "name": "front-page",
      "postTypes": ["page"],
      "title": "Front Page"
    },
    {
      "name": "page-full-width",
      "postTypes": ["page"],
      "title": "Full Width Page"
    },
    {
      "name": "page-services",
      "postTypes": ["page"],
      "title": "Services Page"
    }
  ],
  "templateParts": [
    {
      "name": "header",
      "area": "header",
      "title": "Header"
    },
    {
      "name": "header-transparent",
      "area": "header",
      "title": "Header Transparent"
    },
    {
      "name": "footer",
      "area": "footer",
      "title": "Footer"
    },
    {
      "name": "sidebar",
      "area": "uncategorized",
      "title": "Sidebar"
    }
  ]
}
